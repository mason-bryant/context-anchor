{
  "authToken": "replace-with-output-of: node -e \"console.log(require('crypto').randomBytes(32).toString('base64url'))\"",
  "allowedHosts": [
    "your-tunnel.ngrok-free.dev"
  ],
  "logging": {
    "file": {
      "enabled": true,
      "dirname": "~/.anchor-mcp/logs",
      "filename": "anchor-mcp-%DATE%.log",
      "level": "info",
      "datePattern": "YYYY-MM-DD",
      "maxSize": "10m",
      "maxFiles": "14d",
      "zippedArchive": true
    },
    "requests": {
      "enabled": false,
      "dirname": "~/.anchor-mcp/logs",
      "filename": "anchor-mcp-requests-%DATE%.log",
      "level": "info",
      "datePattern": "YYYY-MM-DD",
      "maxSize": "10m",
      "maxFiles": "14d",
      "zippedArchive": true,
      "includeArguments": true,
      "redactArguments": true
    },
    "traces": {
      "enabled": false,
      "dirname": "~/.anchor-mcp/logs",
      "filename": "anchor-mcp-traces-%DATE%.log",
      "maxSize": "10m",
      "maxFiles": "365d",
      "zippedArchive": true,
      "includeTaskText": false
    }
  }
}
