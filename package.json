{
  "name": "@mason/anchor-mcp",
  "version": "3.0.0",
  "description": "Git-backed MCP server for context anchors with write-time discipline enforcement.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mason-bryant/context-conductor.git"
  },
  "bugs": {
    "url": "https://github.com/mason-bryant/context-conductor/issues"
  },
  "homepage": "https://github.com/mason-bryant/context-conductor#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "anchor-mcp": "./dist/bin/anchor-mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "QUICKSTART.md",
    "AGENTS.md",
    "docs/maintainers.md",
    "docs/milestones.md",
    "docs/operator-reference.md",
    "docs/planner-judge-prompt.md",
    "docs/project-updates.md",
    "docs/proposed-changes.md",
    "githooks/README.md",
    "githooks/pre-push",
    "scripts/anchor-context-sync.sh",
    "scripts/perf-read-paths.ts",
    "scripts/planner-eval.ts",
    "scripts/release.sh"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "install-git-hooks": "git config core.hooksPath githooks",
    "test": "vitest run",
    "eval": "tsx scripts/planner-eval.ts",
    "perf:read-paths": "tsx scripts/perf-read-paths.ts",
    "dev:stdio": "tsx src/bin/anchor-mcp.ts --repo ./fixtures/demo-context",
    "dev:http": "tsx src/bin/anchor-mcp.ts --repo ./fixtures/demo-context --transport http --port 3333",
    "dev:http:watch": "tsx watch src/bin/anchor-mcp.ts --repo ./fixtures/demo-context --transport http --port 3333"
  },
  "engines": {
    "node": ">=20.10"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/express": "2.0.0-alpha.2",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "cors": "^2.8.5",
    "cytoscape": "^3.34.0",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.16.0",
    "simple-git": "^3.28.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
